// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// User model - kept from original schema
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Product model - for e-commerce catalog
model Product {
  id                 String   @id @default(cuid())
  name               String
  slug               String   @unique
  category           String
  price              Int      // Price in GNF (Guinean Franc)
  shortDescription   String
  longDescription    String
  characteristics    String   // JSON string
  highlights         String   // JSON string
  image              String   // Main product image
  images             String   // JSON array of images
  compatibility      String?  // JSON string, optional
  stockQuantity      Int      @default(0)
  inStock            Boolean  @default(true)
  featured           Boolean  @default(false)
  rating             Float    @default(5.0)
  variants           String?  // JSON: [{name, options: [{label, price?}]}]
  tags               String?  // JSON array of tags
  originalPrice      Int?     // Prix barré avant promotion (optionnel)
  isRealPhoto        Boolean  @default(false) // Photo réelle du produit
  badge              String?  // Badge personnalisé ex: "Sélection premium"
  isNew              Boolean  @default(false) // Nouveau produit
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

// Order model - for order management
model Order {
  id             String   @id @default(cuid())
  customerName   String
  customerPhone  String
  customerEmail  String?
  customerAddress String?
  items          String   // JSON array of order items
  totalAmount    Int      // Total in GNF
  status         String   @default("pending") // pending/confirmed/shipped/delivered/cancelled
  paymentMethod  String   @default("cash") // cash/orange_money/mtn_money
  paymentStatus  String   @default("pending") // pending/completed/failed
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

// Admin model - for admin user management
model Admin {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String   // Hashed password
  name      String
  role      String   @default("admin") // admin/moderator/support
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ContactMessage model - for contact form submissions
model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

// Customer model - for customer authentication
model Customer {
  id        String   @id @default(cuid())
  name      String
  phone     String   @unique
  email     String?
  password  String   // Hashed password
  address   String?
  city      String?  @default("Conakry")
  orders    String?  // JSON array of order IDs for quick reference
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Coupon model - for discount codes
model Coupon {
  id          String   @id @default(cuid())
  code        String   @unique
  type        String   @default("percentage") // percentage | fixed
  value       Int      // Pourcentage (ex: 10) ou montant fixe en GNF
  minOrder    Int?     // Montant minimum de commande
  maxUses     Int?     // Nombre max d'utilisations
  usedCount   Int      @default(0)
  active      Boolean  @default(true)
  expiresAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Review model - for product reviews
model Review {
  id         String   @id @default(cuid())
  productId  String
  customerId String?
  customerName String
  rating     Int      // 1-5
  comment    String
  approved   Boolean  @default(false)
  createdAt  DateTime @default(now())
}

// SiteSettings model - for site configuration
model SiteSettings {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

// Newsletter model - for email subscriptions
model Newsletter {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}
