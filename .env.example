# ============================================
# MARCHÉ ROYAL DE GUINÉE - Variables d'environnement
# ============================================
# Copiez ce fichier en .env.local et renseignez vos valeurs.

# Facebook Pixel ID (Gestionnaire d'événements Facebook)
NEXT_PUBLIC_FB_PIXEL_ID=

# Google Analytics 4 Measurement ID (ex: G-XXXXXXXXXX)
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Base de données (Prisma)
DATABASE_URL="file:./db/custom.db"
